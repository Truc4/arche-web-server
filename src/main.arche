#import { os net fmt parse "./server" }

[256]TrieNode;

main :: proc() {
  os.argv(1)(portstr:);
  port := parse.atoi(portstr);
  if (!port) {
    port = 8000;
  }
  os.argv(2)(root:);

  register();

  net.listen(port)(srv:);
  fmt.printf("arche-web-server listening on port %d\n", port);

  for (;;) {
    net.accept(srv)(conn:);
    handle(conn, root);
  }
}
